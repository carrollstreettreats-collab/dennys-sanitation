rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Route notices — anyone can read, only authenticated users can write
    match /notices/{noticeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Site config — anyone can read, only authenticated users can write
    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
